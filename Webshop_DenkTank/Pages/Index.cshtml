@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<!-- HERO BANNER -->
<section class="hero">
    <div class="hero-content">
        <h1>Matrix Inc</h1>
        <p>Al uw bouw benodigdheden op één plek</p>
        <a href="/Products" class="btn-hero">Bekijk Collectie</a>
    </div>
</section>

<!-- UITGELICHTE PRODUCTEN -->
<section class="featured-section">
    <h2>Uitgelicht</h2>

    <div class="product-grid">
        @foreach (var p in Model.FeaturedProducts)
        {
            <div class="product-card">
                <a href="/ProductDetail?id=@p.Id"><img src="@p.ImageUrl" alt="@p.Name" /></a>
                <h3>@p.Name</h3>

                <div class="meta">
                    <p class="price">€@p.Price</p>
                    @if (p.Stock == 0)
                    {
                        <p class="stock out">Uitverkocht</p>
                    }
                    else if (p.Stock < 3)
                    {
                        <p class="stock low">Nog @p.Stock beschikbaar</p>
                    }
                    else
                    {
                        <p class="stock in">Op voorraad</p>
                    }
                </div>

                <div class="card-actions">
                    <a href="/ProductDetail?id=@p.Id" class="btn-card">Bekijk</a>
                </div>
            </div>
        }
    </div>
</section>