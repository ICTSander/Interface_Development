@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<!-- HERO BANNER -->
<section class="hero">
    <div class="hero-content">
        <h1>Premium Designer Collectie 2026</h1>
        <p>Ontdek onze exclusieve nieuwe collectie — elegant, modern en tijdloos.</p>
        <a href="/Products" class="btn-hero">Bekijk Collectie</a>
    </div>
</section>

<!-- UITGELICHTE PRODUCTEN -->
<section class="featured-section">
    <h2>Uitgelicht</h2>

    <div class="featured-grid">
        @foreach (var p in Model.FeaturedProducts)
        {
            <div class="featured-card">
                <img src="@p.ImageUrl" alt="@p.Name" />
                <h3>@p.Name</h3>

                <p class="price">€@p.Price</p>

                @if (p.Stock == 0)
                {
                    <p class="stock out">Uitverkocht</p>
                }
                else if (p.Stock < 3)
                {
                    <p class="stock low">Nog @p.Stock beschikbaar</p>
                }
                else
                {
                    <p class="stock in">Op voorraad</p>
                }

                <a href="/ProductDetail?id=@p.Id" class="btn-card">Bekijk</a>
            </div>
        }
    </div>
</section>