@page
@model LoginModel
@{
    ViewData["Title"] = "Inloggen";
}

<div class="auth-container">
    <div class="auth-card">
        <h1>Inloggen</h1>
        <p class="auth-subtitle">Welkom terug bij DenkTank Webshop</p>

        @if (Model.ErrorMessage != null)
        {
            <div class="alert-error">@Model.ErrorMessage</div>
        }

        <form method="post">
            <div class="form-group">
                <label for="Email">E-mailadres</label>
                <input type="email" id="Email" name="Email" placeholder="jouw@email.nl" required />
            </div>

            <div class="form-group">
                <label for="Password">Wachtwoord</label>
                <input type="password" id="Password" name="Password" placeholder="••••••••" required />
            </div>

            <div class="form-options">
                <label class="checkbox-label">
                    <input type="checkbox" name="RememberMe" /> Onthoud mij
                </label>
                <a href="#" class="forgot-link">Wachtwoord vergeten?</a>
            </div>

            <button type="submit" class="btn-auth">Inloggen</button>
        </form>

        <div class="auth-divider">
            <span>— Testfase —</span>
        </div>

        <button type="button" class="btn-quick-login" onclick="quickLogin()">⚡ Snel inloggen (test)</button>

        <div class="auth-divider">
            <span>Nog geen account?</span>
        </div>

        <a href="#" class="btn-auth-secondary">Registreren</a>
    </div>
</div>

<script>
    function quickLogin() {
        document.getElementById('Email').value = 'demo@denktank.nl';
        document.getElementById('Password').value = 'Demo1234!';
        document.querySelector('form').submit();
    }
</script>
